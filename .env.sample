# Azure AI Foundry project endpoint
# Example: https://<resource>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=

# Model deployment name
AZURE_AI_MODEL_DEPLOYMENT_NAME=

# Optional: Azure OpenAI endpoint for local stage scripts
# Example: https://<resource>.openai.azure.com
AZURE_OPENAI_ENDPOINT=

# Optional: Foundry IQ / Azure AI Search endpoint (stage2 direct KB access only)
# Example: https://<search-service>.search.windows.net
AZURE_AI_SEARCH_SERVICE_ENDPOINT=

# Optional: Knowledge base name (stage2 direct KB access only;
# stage3+ access KB via the Foundry Toolbox instead)
AZURE_AI_SEARCH_KNOWLEDGE_BASE_NAME=zava-company-kb

# Optional: Project connection name in Azure AI Foundry
AZURE_AI_SEARCH_CONNECTION_NAME=

# Optional: Toolbox name created by infra/create-toolbox.py
CUSTOM_FOUNDRY_AGENT_TOOLBOX_NAME=hr-agent-tools

# Optional: Local telemetry for hosted-agent debugging
APPLICATIONINSIGHTS_CONNECTION_STRING=
